{
  "title": "ETH RPC Latency Comparison",
  "uid": "eth-rpc-latency",
  "version": 2,
  "panels": [
    {
      "title": "PublicNode — eth_blockNumber",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "eth_rpc_publicnode_latency_seconds * 1000",
          "legendFormat": "PublicNode"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "unit": "ms"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "showLegend": true
        }
      }
    },
    {
      "title": "Alchemy — eth_blockNumber",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "eth_rpc_alchemy_latency_seconds * 1000",
          "legendFormat": "Alchemy"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "unit": "ms"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "showLegend": true
        }
      }
    },
    {
      "title": "RPC latency comparison",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "eth_rpc_publicnode_latency_seconds * 1000",
          "legendFormat": "PublicNode"
        },
        {
          "expr": "eth_rpc_alchemy_latency_seconds * 1000",
          "legendFormat": "Alchemy"
        },
        {
          "expr": "eth_rpc_publicnode_latency_seconds / eth_rpc_alchemy_latency_seconds",
          "legendFormat": "Ratio (PublicNode / Alchemy)"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "ms"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Ratio (PublicNode / Alchemy)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "none"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["last"],
          "displayMode": "list",
          "showLegend": true
        }
      }
    }
  ]
}
